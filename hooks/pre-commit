#!/bin/bash

PYTHON="python"
command -v "$PYTHON" >/dev/null 2>&1 || PYTHON="python3"
command -v "$PYTHON" >/dev/null 2>&1 || PYTHON="python.exe"

WIN_TEMP="$(powershell.exe -Command 'Write-Host $env:TEMP' 2>/dev/null | tr -d '\r')"
WSL_TEMP="$(wslpath "$WIN_TEMP" 2>/dev/null || echo "/tmp")"

# Step 1: Extract DAX từ live model
echo "Extracting DAX measures..."
powershell.exe -ExecutionPolicy Bypass -File "scripts/extract_dax.ps1" -OutputDir "./source"
if [ $? -ne 0 ]; then
    echo "ERROR: Make sure the .pbix file is open in PBI Desktop RS."
    exit 1
fi

# Step 2: Skip eval nếu không có measure nào thay đổi
CHANGED=$(git diff --name-only source/measures/ 2>/dev/null)
if [ -z "$CHANGED" ]; then
    echo "No measure changes — skip preview."
    git add source/ 2>/dev/null
    exit 0
fi

echo "Changed measures:"
echo "$CHANGED"

# Step 3: Eval chỉ khi có thay đổi
echo "Evaluating measures..."
powershell.exe -ExecutionPolicy Bypass -File "scripts/eval_measures.ps1"
if [ $? -ne 0 ]; then
    echo "ERROR: eval_measures.ps1 failed"
    exit 1
fi

# Step 4: Tạo HTML preview
"$PYTHON" scripts/generate_preview.py "$WSL_TEMP/pbirs_measures.json" "$WSL_TEMP/pbirs_preview.html"

# Step 5: Mở browser
case "$(uname -s)" in
    Darwin*)              open "$WSL_TEMP/pbirs_preview.html" ;;
    CYGWIN*|MINGW*|MSYS*) start "$WIN_TEMP\\pbirs_preview.html" ;;
    Linux*)
        if grep -qi microsoft /proc/version 2>/dev/null; then
            explorer.exe "$(wslpath -w "$WSL_TEMP/pbirs_preview.html")"
        else
            xdg-open "$WSL_TEMP/pbirs_preview.html"
        fi ;;
esac

# Step 6: Xác nhận
if [ -t 0 ]; then
    read -p "Tiep tuc commit? (y/n): " confirm
    [ "$confirm" != "y" ] && echo "Commit huy" && exit 1
else
    echo "Khong co terminal — tu dong tiep tuc"
fi

git add source/ .measures_cache.json 2>/dev/null
