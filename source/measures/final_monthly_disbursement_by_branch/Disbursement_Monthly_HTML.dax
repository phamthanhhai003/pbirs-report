        "<td class='ac'>" & IF( IFERROR(VALUE([pct]),0)=0, "<span class='zero'>-</span>", IF( IFERROR(VALUE([pct]),0)<=1, "<span style='color:#16a34a;'>" & FORMAT(IFERROR(VALUE([pct]),0)*100,"0.0") & "%</span>", "<span style='color:#dc2626;'>" & FORMAT(IFERROR(VALUE([pct]),0)*100,"0.0") & "%</span>" ) ) & "</td>" &
        "</tr>",
        , IFERROR( VALUE([Credit_Product_No]), 99 ), ASC
    )
VAR Sub =
    "<tr class='st'><td></td><td>TOTAL</td>" &
    "<td class='ar tg'></td><td class='ar' style='font-weight:800;'>" &
    IF( GT_disb=0, "<span class='zero'>-</span>", FORMAT(GT_disb,"#,##0.00") ) &
    "</td><td class='ac' style='font-weight:800;'>" &
    IF( GT_cli=0, "<span class='zero'>-</span>", FORMAT(GT_cli,"#,##0") ) &
    "</td><td class='ar'><span class='zero'>-</span></td><td class='ac'><span class='zero'>-</span></td></tr>"
VAR BH_DILI     = "<tr class='bh'><td colspan='7'>DILI</td></tr>"
VAR BH_GLENO    = "<tr class='bh'><td colspan='7'>GLENO</td></tr>"
VAR BH_MALIANA  = "<tr class='bh'><td colspan='7'>MALIANA</td></tr>"
