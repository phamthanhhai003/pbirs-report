VAR GrandTotal =
    "<tr class='gt'><td></td><td>GRAND TOTAL (ALL BRANCHES)</td>" &
    "<td class='ar'>" & IF( GT_tgt=0, " - ", FORMAT(GT_tgt,"#,##0.00") ) & "</td>" &
    "<td class='ar'>" & IF( GT_disb=0, " - ", FORMAT(GT_disb,"#,##0.00") ) & "</td>" &
    "<td class='ar'>" & IF( GT_cli=0, " - ", FORMAT(GT_cli,"#,##0") ) & "</td>" &
    "<td class='ar'>" & IF( GT_tgt=0, " - ", IF( GT_var>=0, "+" & FORMAT(GT_var,"#,##0.00"), "(" & FORMAT(ABS(GT_var),"#,##0.00") & ")" ) ) & "</td>" &
    "<td class='ar'>" & IF( GT_pct=0, " - ", FORMAT(GT_pct*100,"0.0") & "%" ) & "</td>" &
    "</tr>"
VAR Ftr =
    "<div style='background:#f8fafc;border-top:1px solid #e2e8f0;padding:7px 15px;display:flex;justify-content:space-between;'>" &
    "<span style='font-size:10px;color:#9ca3af;'>All amounts in USD</span>" &
    "<span style='font-size:10px;color:#9ca3af;'>BNCTL  -  Confidential</span>" &
    "</div>"
RETURN
    "<div class='dm'>" & Sty & Hdr &
    "<div style='overflow-x:auto;'>" & TH &
    BH_DILI     & PRow_DILI     & ST_DILI     &
    BH_GLENO    & PRow_GLENO    & ST_GLENO    &
    BH_MALIANA  & PRow_MALIANA  & ST_MALIANA  &
    BH_AILEU    & PRow_AILEU    & ST_AILEU    &
    BH_OECUSSE  & PRow_OECUSSE  & ST_OECUSSE  &
    BH_BAUCAU   & PRow_BAUCAU   & ST_BAUCAU   &
    BH_SAME     & PRow_SAME     & ST_SAME     &
    BH_AINARO   & PRow_AINARO   & ST_AINARO   &
