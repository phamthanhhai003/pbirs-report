        "<tr class='pr'><td class='no'>" & [Credit_Product_No] & "</td><td>" & [Credit_Product] & "</td>" &
        "<td class='ar tg'>" & IF( IFERROR(VALUE([monthly_target]),0)=0, "<span class='zero'>-</span>", FORMAT(IFERROR(VALUE([monthly_target]),0),"#,##0.00") ) & "</td>" &
        "<td class='ar' style='font-weight:600;'>" & IF( IFERROR(VALUE([total_disbursement]),0)=0, "<span class='zero'>-</span>", FORMAT(IFERROR(VALUE([total_disbursement]),0),"#,##0.00") ) & "</td>" &
        "<td class='ac'>" & IF( IFERROR(VALUE([total_clients]),0)=0, "<span class='zero'>-</span>", FORMAT(IFERROR(VALUE([total_clients]),0),"#,##0") ) & "</td>" &
        "<td class='ar'>" & IF( IFERROR(VALUE([monthly_target]),0)=0, "<span class='zero'>-</span>", IF( IFERROR(VALUE([variance]),0)>=0, "<span style='color:#16a34a;font-weight:600;'>+" & FORMAT(IFERROR(VALUE([variance]),0),"#,##0.00") & "</span>", "<span style='color:#dc2626;font-weight:600;'>(" & FORMAT(ABS(IFERROR(VALUE([variance]),0)),"#,##0.00") & ")</span>" ) ) & "</td>" &
        "<td class='ac'>" & IF( IFERROR(VALUE([pct]),0)=0, "<span class='zero'>-</span>", IF( IFERROR(VALUE([pct]),0)<=1, "<span style='color:#16a34a;'>" & FORMAT(IFERROR(VALUE([pct]),0)*100,"0.0") & "%</span>", "<span style='color:#dc2626;'>" & FORMAT(IFERROR(VALUE([pct]),0)*100,"0.0") & "%</span>" ) ) & "</td>" &
        "</tr>",
        , IFERROR( VALUE([Credit_Product_No]), 99 ), ASC
    )
VAR PRow_LIQUICA =
    CONCATENATEX(
        FILTER( tbl, [Branch] = "LIQUICA" && NOT ISBLANK( [Credit_Product_No] ) ),
        "<tr class='pr'><td class='no'>" & [Credit_Product_No] & "</td><td>" & [Credit_Product] & "</td>" &
        "<td class='ar tg'>" & IF( IFERROR(VALUE([monthly_target]),0)=0, "<span class='zero'>-</span>", FORMAT(IFERROR(VALUE([monthly_target]),0),"#,##0.00") ) & "</td>" &
