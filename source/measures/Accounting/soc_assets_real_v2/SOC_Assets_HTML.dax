MEASURE 'soc_assets_real_v2'[SOC_Assets_HTML] =
VAR SelectedYear  = SELECTEDVALUE( Calendar[Year] )
VAR SelectedMonth = SELECTEDVALUE( Calendar[report_month] )
VAR MaxMonth      = MAX( soc_assets_real_v2[report_month] )
VAR MaxYear       = LEFT( MaxMonth, 4 )
VAR ActiveYear    = IF( ISBLANK(SelectedYear), MaxYear, SelectedYear )
VAR ActiveMonth   = IF( ISBLANK(SelectedMonth), MaxMonth, SelectedMonth )
VAR PeriodLabel   =
    IF( NOT ISBLANK(SelectedMonth),
        "For the Month of " & FORMAT( DATE( LEFT(ActiveMonth,4), RIGHT(ActiveMonth,2), 1 ), "MMMM YYYY" ),
        "For the Year Ended " & ActiveYear )
VAR tbl = FILTER( ALL(soc_assets_real_v2),
    IF( NOT ISBLANK(SelectedMonth), [report_month]=ActiveMonth, LEFT([report_month],4)=ActiveYear ) )
VAR o1_CURR_ac = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="CURR"), IFERROR(VALUE([accts]),0) )
VAR o1_CURR_am = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="CURR"), IFERROR(VALUE([amount]),0) )
VAR o1_PREV_ac = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="PREV"), IFERROR(VALUE([accts]),0) )
VAR o1_PREV_am = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="PREV"), IFERROR(VALUE([amount]),0) )
VAR o1_YOY_ac = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="YOY"), IFERROR(VALUE([accts]),0) )
VAR o1_YOY_am = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="YOY"), IFERROR(VALUE([amount]),0) )
VAR o1_CI = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="CURR"), IFERROR(VALUE([increase_prev_period]),0) )
VAR o1_CP = AVERAGEX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="CURR"), IFERROR(VALUE([pct_change_prev_period]),0) )
VAR o1_YI = SUMX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="YOY"), IFERROR(VALUE([increase_prev_period]),0) )
VAR o1_YP = AVERAGEX( FILTER(tbl, VALUE([order_id])=1 && [type_period]="YOY"), IFERROR(VALUE([pct_change_prev_period]),0) )
