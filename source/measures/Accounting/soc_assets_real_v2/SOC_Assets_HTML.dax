    ".tot td{background:#f0a500!important;font-weight:800;font-size:11px;color:#003366!important;border-top:2px solid #003366!important;}" &
    ".cd{color:#9ca3af;font-size:9px;min-width:80px;}" &
    ".cd-w{color:#f0a500!important;font-size:9px;min-width:80px;}" &
    ".ar{text-align:right!important;font-family:Consolas,monospace;font-size:9.5px;min-width:90px;}" &
    ".ac{text-align:center!important;font-family:Consolas,monospace;font-size:9.5px;min-width:50px;}" &
    ".pct{text-align:center!important;font-size:9.5px;min-width:60px;}" &
    ".bl{border-left:2px solid #dde4ef!important;}" &
    ".i0{padding-left:8px!important;}" &
    ".i1{padding-left:18px!important;}" &
    ".i2{padding-left:28px!important;}" &
    ".i3{padding-left:38px!important;color:#6b7280;}" &
    ".i4{padding-left:48px!important;color:#9ca3af;}" &
    "</style>"
VAR Hdr =
    "<div style='background:#003366;padding:16px 20px 12px;border-bottom:4px solid #f0a500;display:flex;align-items:center;gap:16px;'>" &
    "<img src='https://i.ibb.co/rWhBLgw/image-2026-04-21-094244962.png' style='height:90px;width:auto;flex-shrink:0;' />" &
    "<div>" &
    "<div style='color:#fff;font-family:Segoe UI,sans-serif;font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;'>BANCO NACIONAL DE COMERCIO DE TIMOR LESTE</div>" &
    "<div style='color:#f0a500;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:3px;'>CONSOLIDATED STATEMENT OF ASSETS AND LIABILITIES (SOC)</div>" &
    "<div style='color:#f0a500;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:3px;'>ASSETS</div>" &
    "<div style='color:#cbd5e1;font-size:11px;'>" & PeriodLabel & "</div>" &
    "</div>" &
    "</div>"
VAR ColHdr =
    "<table class='soc-t'><thead>" &
    "<tr style='background:#1a4a7a;'>" &
    "<td class='cd-w' rowspan='2' style='padding:5px 7px;'>CODE</td>" &
    "<td style='color:#fff;font-weight:700;font-size:10px;padding:5px 7px;' rowspan='2'>ACCOUNT TITLES</td>" &
    "<td style='color:#fff;font-weight:700;font-size:10px;padding:5px 7px;text-align:center;border-left:2px solid #2563eb;' colspan='2'>CURRENT PERIOD</td>" &
    "<td style='color:#fff;font-weight:700;font-size:10px;padding:5px 7px;text-align:center;border-left:2px solid #2563eb;'>PREVIOUS PERIOD</td>" &
    "<td style='color:#f0a500;font-weight:700;font-size:10px;padding:5px 7px;text-align:center;border-left:2px solid #2563eb;' colspan='2'>vs PREVIOUS</td>" &
    "<td style='color:#fff;font-weight:700;font-size:10px;padding:5px 7px;text-align:center;border-left:2px solid #2563eb;'>PREV YEAR</td>" &
    "<td style='color:#f0a500;font-weight:700;font-size:10px;padding:5px 7px;text-align:center;border-left:2px solid #2563eb;' colspan='2'>YOY CHANGE</td>" &
    "</tr>" &
    "<tr style='background:#1a4a7a;border-bottom:2px solid #f0a500;'>" &
    "<td class='ac' style='color:#d1d5db;font-size:9px;padding:3px 7px;border-left:2px solid #2563eb;'>No.Acc</td>" &
    "<td class='ar' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>Amount (USD)</td>" &
    "<td class='ar bl' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>Amount (USD)</td>" &
    "<td class='ar bl' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>Increase (+/-)</td>" &
    "<td class='pct' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>%</td>" &
    "<td class='ar bl' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>Amount (USD)</td>" &
    "<td class='ar bl' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>Variance</td>" &
    "<td class='pct' style='color:#d1d5db;font-size:9px;padding:3px 7px;'>%</td>" &
    "</tr></thead><tbody>"
VAR Rows_1 =
    "<tr class='sub1'><td class='cd'>1.0</td><td class='i1'>ASSETS:</td>" & "<td class='ac bl'>" & IF(o1_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o1_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o1_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o1_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o1_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o1_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o1_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o1_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o1_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o1_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o1_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o1_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o1_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o1_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o1_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o1_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o1_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o1_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o1_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o1_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr class='sub1'><td class='cd'>1.01</td><td class='i1'>LIQUID FUNDS</td>" & "<td class='ac bl'>" & IF(o2_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o2_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o2_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o2_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o2_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o2_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o2_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o2_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o2_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o2_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o2_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o2_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o2_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o2_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o2_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o2_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o2_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o2_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o2_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o2_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr><td class='cd'>1.01.1.1.1</td><td class='i4'>Cash in Vault</td>" & "<td class='ac bl'>" & IF(o3_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o3_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o3_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o3_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o3_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o3_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o3_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o3_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o3_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o3_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o3_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o3_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o3_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o3_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o3_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o3_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o3_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o3_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o3_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o3_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o3_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o3_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o3_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o3_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr><td class='cd'>1.01.1.1.2</td><td class='i4'>Cash in ATM Vault</td>" & "<td class='ac bl'>" & IF(o4_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o4_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o4_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o4_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o4_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o4_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o4_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o4_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o4_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o4_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o4_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o4_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o4_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o4_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o4_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o4_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o4_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o4_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o4_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o4_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o4_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o4_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o4_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o4_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr class='sub2'><td class='cd'>1.01.2</td><td class='i2'>Due from Central Bank</td>" & "<td class='ac bl'>" & IF(o5_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o5_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o5_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o5_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o5_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o5_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o5_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o5_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o5_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o5_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o5_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o5_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o5_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o5_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o5_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o5_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o5_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o5_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o5_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o5_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o5_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o5_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o5_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o5_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr class='sub2'><td class='cd'>1.01.3</td><td class='i2'>Items in course of collect.</td>" & "<td class='ac bl'>" & IF(o6_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o6_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o6_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o6_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o6_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o6_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o6_CI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o6_CI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o6_CI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o6_CI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o6_CP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o6_CP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o6_CP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o6_CP*-1)*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o6_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o6_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF((o6_YI*-1)<0.01,"<span style='color:#d1d5db'>-</span>",IF((o6_YI*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o6_YI*-1),"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT((o6_YI*-1),"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF((o6_YP*-1)<0.0001,"<span style='color:#d1d5db'>-</span>",IF((o6_YP*-1)>0,"<span style='color:#16a34a'>+" & FORMAT((o6_YP*-1)*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT((o6_YP*-1)*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
