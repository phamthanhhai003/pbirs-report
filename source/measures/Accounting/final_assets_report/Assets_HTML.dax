MEASURE 'final_assets_report'[Assets_HTML] =
VAR SelectedBranch = SELECTEDVALUE( final_assets_report[branch_name] )
VAR MaxDate   = CALCULATE( MAX( final_assets_report[load_date] ), ALL(final_assets_report) )
VAR SelReportMonth = SELECTEDVALUE( Calendar[report_month] )
VAR SelYear        = SELECTEDVALUE( Calendar[Year] )
VAR SelMonthNum    = SELECTEDVALUE( Calendar[MonthNum] )
VAR ActiveMonth =
    IF( NOT ISBLANK(SelReportMonth), SelReportMonth,
    IF( NOT ISBLANK(SelYear) && NOT ISBLANK(SelMonthNum),
        SelYear & "-" & FORMAT(SelMonthNum,"00"),
    IF( NOT ISBLANK(SelYear),
        MAXX( FILTER(ALL(final_assets_report), LEFT([load_date], 4)=SelYear),
              LEFT([load_date], 7) ),
        LEFT(MaxDate, 7) )))
VAR PeriodLabel = FORMAT( DATE(VALUE(LEFT(ActiveMonth,4)),VALUE(RIGHT(ActiveMonth,2)),1), "MMMM YYYY" )
VAR tbl = FILTER( ALL(final_assets_report), LEFT([load_date], 7) = ActiveMonth )

-- ============================================================
-- BRANCH FILTER HELPERS (amounts stored as negative, use ABS)
-- ============================================================
-- Branch mapping: UPGRADE=Head Office, DILI=Dili, GLENO=Gleno, MALIANA=Maliana
-- AILEU=Aileu, CUSSE=Oe-Cusse, BAUCAU=Baucau, SAME=Same, AINARO=Ainaro
-- SUAI=Suai, VIQUEQUE=Viqueque, LOSPALOS=Lospalos, LIQUICA=Liquica, MANATUTO=Manatuto
-- Consolidated = SUM all branches

-- Macro: get amount for a given order_id + branch
-- Amount stored as negative â†’ use ABS

-- HEAD OFFICE (UPGRADE)
VAR HO3   = SUMX(FILTER(tbl,[order_id]=3   && [branch_name]="UPGRADE"),IFERROR(VALUE([amount]),0))
