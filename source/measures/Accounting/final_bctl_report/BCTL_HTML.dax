    "<tr class='net'><td class='cd-w'></td><td class='i0'>NET INCOME (LOSS) BEFORE TAX</td><td class='ar'>" & IF(ISBLANK(s5r68) || s5r68=0,"<span style='color:#d1d5db'>-</span>",IF(s5r68<0,"<span style='color:#dc2626'>(" & FORMAT(s5r68,"#,##0.00") & ")</span>",FORMAT(s5r68,"#,##0.00"))) & "</td></tr>" &
    "<tr class='sub1'><td class='cd'>5.09</td><td class='i1'>PROVISION FOR INCOME TAX</td><td class='ar'>" & IF(ISBLANK(s5r69) || s5r69=0,"<span style='color:#d1d5db'>-</span>",IF(s5r69<0,"<span style='color:#dc2626'>(" & FORMAT(s5r69,"#,##0.00") & ")</span>",FORMAT(s5r69,"#,##0.00"))) & "</td></tr>" &
    "<tr class='net'><td class='cd-w'></td><td class='i0'>NET INCOME (LOSS) AFTER TAX</td><td class='ar'>" & IF(ISBLANK(s5r70) || s5r70=0,"<span style='color:#d1d5db'>-</span>",IF(s5r70<0,"<span style='color:#dc2626'>(" & FORMAT(s5r70,"#,##0.00") & ")</span>",FORMAT(s5r70,"#,##0.00"))) & "</td></tr>"
VAR Sec7_1 =
