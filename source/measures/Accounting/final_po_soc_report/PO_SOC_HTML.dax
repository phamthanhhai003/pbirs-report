VAR f = "#,##0.00"
VAR z = "<span style='color:#d1d5db'>-</span>"
VAR StyleBlock =
    "<style>" &
    ".soc{font-family:Segoe UI,Calibri,sans-serif;font-size:11px;color:#1e2d40;}" &
    ".soc-t{width:100%;border-collapse:collapse;}" &
    ".soc-t td{padding:3px 12px;border-bottom:1px solid #e8edf3;vertical-align:middle;}" &
    ".soc-t tr:hover td{background:#f5f8ff;}" &
    ".h-row td{background:#003366!important;color:#fff!important;font-weight:700;font-size:12px;text-transform:uppercase;border-bottom:3px solid #f0a500!important;padding:7px 12px!important;}" &
    ".sub1 td{background:#e8f0fb!important;font-weight:700;color:#003366;border-bottom:1px solid #b8cce4!important;}" &
    ".sub2 td{background:#f0f6ff!important;font-weight:600;color:#1a4a7a;}" &
    ".tot td{background:#f0a500!important;font-weight:800;font-size:12px;color:#003366!important;border-top:2px solid #003366!important;}" &
    ".chk td{background:#fff8e8!important;font-weight:600;color:#92400e!important;}" &
    ".cd{color:#9ca3af;font-size:9px;width:110px;}" &
    ".cd-w{color:#f0a500!important;font-size:9px;width:110px;}" &
    ".ar{text-align:right!important;font-family:Consolas,monospace;font-size:10px;white-space:nowrap;width:130px;}" &
    ".i1{padding-left:20px!important;}" &
    ".i2{padding-left:32px!important;}" &
    ".i3{padding-left:44px!important;color:#6b7280;}" &
    ".i4{padding-left:56px!important;color:#9ca3af;}" &
    "</style>"
VAR ModernHeader =
    "<div style='background:#003366;padding:16px 25px 12px;border-bottom:4px solid #f0a500;display:flex;align-items:center;gap:16px;'>" &
    "<img src='https://i.ibb.co/rWhBLgw/image-2026-04-21-094244962.png' style='height:90px;width:auto;flex-shrink:0;' />" &
    "<div>" &
    "<div style='color:#fff;font-family:Segoe UI,sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;'>BANCO NACIONAL DE COMERCIO DE TIMOR LESTE</div>" &
    "<div style='color:#f0a500;font-family:Segoe UI,sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:6px;'>STATEMENT OF CONDITION &mdash; ASSETS &amp; LIABILITIES (PO SOC)</div>" &
    "<div style='color:#cbd5e1;font-family:Segoe UI,sans-serif;font-size:12px;'>" & PeriodLabel & "</div>" &
    "</div>" &
    "</div>"
VAR TH = "<table class='soc-t'><thead><tr style='background:#f8fafc;'><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:110px;'>CODE</td><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;'>DESCRIPTION</td><td style='text-align:right;font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:130px;'>AMOUNT (USD)</td></tr></thead><tbody>"
VAR TableHTML = TH &
    "<tr class='h-row'><td class='cd-w'>1.0</td><td>A S S E T S</td><td class='ar'></td></tr>" &
    "<tr class='sub1'><td class='cd'>1.01</td><td class='i1'>LIQUID FUNDS</td><td class='ar'>" & IF(r9=0,z,FORMAT(r9,f)) & "</td></tr>" &
    "<tr><td class='cd'>1.01.1.1</td><td class='i2'>Cash in Vault / on hand</td><td class='ar'>" & IF(r10=0,z,FORMAT(r10,f)) & "</td></tr>" &
    "<tr><td class='cd'>1.01.1.2</td><td class='i2'>Cash in ATM Vault</td><td class='ar'>" & IF(r11=0,z,FORMAT(r11,f)) & "</td></tr>" &
