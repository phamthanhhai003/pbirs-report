MEASURE 'final_balance_sheet_liabilities_report'[BS_Liabilities_HTML] =
VAR SelectedYear  = SELECTEDVALUE( Calendar[Year] )
VAR SelectedMonth = SELECTEDVALUE( Calendar[report_month] )
VAR MaxMonth      = MAX( final_balance_sheet_liabilities_report[report_month] )
VAR MaxYear       = LEFT( MaxMonth, 4 )
VAR ActiveYear    = IF( ISBLANK(SelectedYear),  MaxYear,  SelectedYear )
VAR ActiveMonth   = IF( ISBLANK(SelectedMonth), MaxMonth, SelectedMonth )
VAR PeriodLabel   =
    IF(
        NOT ISBLANK(SelectedMonth),
        "For the Month of " & FORMAT( DATE( LEFT(ActiveMonth,4), RIGHT(ActiveMonth,2), 1 ), "MMMM YYYY" ),
        "For the Year Ended " & ActiveYear
    )
VAR tbl =
    FILTER( ALL(final_balance_sheet_liabilities_report),
        IF(
            NOT ISBLANK(SelectedMonth),
            [report_month] = ActiveMonth,
            LEFT( [report_month], 4 ) = ActiveYear
        )
    )
VAR v21    = SUMX( FILTER( tbl, [code] = "2.1"    ), [amount] )
VAR v211   = SUMX( FILTER( tbl, [code] = "2.1.1"  ), [amount] )
VAR v212   = SUMX( FILTER( tbl, [code] = "2.1.2"  ), [amount] )
VAR v213   = SUMX( FILTER( tbl, [code] = "2.1.3"  ), [amount] )
VAR v22    = SUMX( FILTER( tbl, [code] = "2.2"    ), [amount] )
VAR v221   = SUMX( FILTER( tbl, [code] = "2.2.1"  ), [amount] )
VAR v222   = SUMX( FILTER( tbl, [code] = "2.2.2"  ), [amount] )
VAR v223   = SUMX( FILTER( tbl, [code] = "2.2.3"  ), [amount] )
VAR v23    = SUMX( FILTER( tbl, [code] = "2.3"    ), [amount] )
VAR v231   = SUMX( FILTER( tbl, [code] = "2.3.1"  ), [amount] )
VAR v232   = SUMX( FILTER( tbl, [code] = "2.3.2"  ), [amount] )
