VAR fv313  = IF(v313  = 0, "<span style='color:#d1d5db'>-</span>", IF(v313  < 0, "<span style='color:#dc2626'>(" & FORMAT(v313, "#,##0") & ")</span>", FORMAT(v313, "#,##0")))
VAR fv314  = IF(v314  = 0, "<span style='color:#d1d5db'>-</span>", IF(v314  < 0, "<span style='color:#dc2626'>(" & FORMAT(v314, "#,##0") & ")</span>", FORMAT(v314, "#,##0")))
VAR fv32   = IF(v32   = 0, "<span style='color:#d1d5db'>-</span>", IF(v32   < 0, "<span style='color:#dc2626'>(" & FORMAT(v32,  "#,##0") & ")</span>", FORMAT(v32,  "#,##0")))
VAR fv321  = IF(v321  = 0, "<span style='color:#d1d5db'>-</span>", IF(v321  < 0, "<span style='color:#dc2626'>(" & FORMAT(v321, "#,##0") & ")</span>", FORMAT(v321, "#,##0")))
