VAR v244   = SUMX( FILTER( tbl, [code] = "2.4.4"  ), [amount] )
VAR v26    = SUMX( FILTER( tbl, [code] = "2.6"    ), [amount] )
VAR v261   = SUMX( FILTER( tbl, [code] = "2.6.1"  ), [amount] )
VAR v262   = SUMX( FILTER( tbl, [code] = "2.6.2"  ), [amount] )
