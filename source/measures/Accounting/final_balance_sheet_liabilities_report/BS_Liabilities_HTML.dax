VAR v35    = SUMX( FILTER( tbl, [code] = "3.5"    ), [amount] )
VAR v36    = SUMX( FILTER( tbl, [code] = "3.6"    ), [amount] )
VAR v361   = SUMX( FILTER( tbl, [code] = "3.6.1"  ), [amount] )
VAR v362   = SUMX( FILTER( tbl, [code] = "3.6.2"  ), [amount] )
VAR vTotLiab = SUMX( FILTER( tbl, [code] = "TOTAL_LIAB" ), [amount] )
VAR vTotCap  = SUMX( FILTER( tbl, [code] = "TOTAL_CAP"  ), [amount] )
VAR vTotAll  = SUMX( FILTER( tbl, [code] = "TOTAL_ALL"  ), [amount] )
VAR fv21   = IF(v21   = 0, "<span style='color:#d1d5db'>-</span>", IF(v21   < 0, "<span style='color:#dc2626'>(" & FORMAT(v21,  "#,##0") & ")</span>", FORMAT(v21,  "#,##0")))
