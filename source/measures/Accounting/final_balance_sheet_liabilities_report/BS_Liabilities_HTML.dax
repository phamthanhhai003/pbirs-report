    "<tr><td class='cd'>2.8.1</td><td class='i1'>Inter Branch Transaction (Net)</td><td class='ar'>" & fv281 & "</td></tr>" &
    "<tr><td class='cd'>2.8.2</td><td class='i1'>Other</td><td class='ar'>" & fv282 & "</td></tr>" &
    "<tr style='background:#003366;'><td style='color:#f0a500;font-size:10px;padding:8px 10px;'></td><td style='padding-left:10px;font-size:12px;font-weight:700;color:#fff;border-top:3px solid #f0a500;border-bottom:2px solid #f0a500;'>TOTAL LIABILITIES</td><td style='text-align:right;font-family:Consolas,monospace;font-size:12px;font-weight:700;color:#fff;border-top:3px solid #f0a500;border-bottom:2px solid #f0a500;'>" & fvTotLiab & "</td></tr>" &
    "<tr style='height:8px;background:#f1f5f9;'><td colspan='3'></td></tr>" &
    "<tr class='sh'><td class='cd-g'>3</td><td class='i0'>C A P I T A L &nbsp; A C C O U N T S</td><td class='ar-w'></td></tr>" &
    "<tr class='sbh'><td class='cd'>3.1</td><td class='i0'>PROVISIONING</td><td class='ar-b'>" & fv31 & "</td></tr>" &
    "<tr><td class='cd'>3.1.1</td><td class='i1'>Provision on Loans</td><td class='ar'>" & fv311 & "</td></tr>" &
    "<tr><td class='cd'>3.1.2</td><td class='i1'>Provision on Securities</td><td class='ar'>" & fv312 & "</td></tr>" &
    "<tr><td class='cd'>3.1.3</td><td class='i1'>Provision on Exchange Rate</td><td class='ar'>" & fv313 & "</td></tr>" &
    "<tr><td class='cd'>3.1.4</td><td class='i1'>Other Provision</td><td class='ar'>" & fv314 & "</td></tr>" &
    "<tr class='sbh'><td class='cd'>3.2</td><td class='i0'>CAPITAL PAID UP AND ASSIGNED</td><td class='ar-b'>" & fv32 & "</td></tr>" &
    "<tr><td class='cd'>3.2.1</td><td class='i1'>Ordinary Shares</td><td class='ar'>" & fv321 & "</td></tr>" &
    "<tr><td class='cd'>3.2.2</td><td class='i1'>Preference Shares</td><td class='ar'>" & fv322 & "</td></tr>" &
    "<tr><td class='cd'>3.2.3</td><td class='i1'>Other</td><td class='ar'>" & fv323 & "</td></tr>" &
    "<tr><td class='cd'>3.3</td><td class='i0' style='font-weight:600;'>Share Premium</td><td class='ar'>" & fv33 & "</td></tr>" &
    "<tr><td class='cd'>3.4</td><td class='i0' style='font-weight:600;'>Reserves</td><td class='ar'>" & fv34 & "</td></tr>" &
    "<tr><td class='cd'>3.5</td><td class='i0' style='font-weight:600;'>Retained Earnings / (Accumulated Deficit)</td><td class='ar'>" & fv35 & "</td></tr>" &
    "<tr class='sbh'><td class='cd'>3.6</td><td class='i0'>UNAPPROPRIATED PROFITS / (LOSSES)</td><td class='ar-b'>" & fv36 & "</td></tr>" &
    "<tr><td class='cd'>3.6.1</td><td class='i1'>Previous Financial Year</td><td class='ar'>" & fv361 & "</td></tr>" &
    "<tr><td class='cd'>3.6.2</td><td class='i1'>Current Financial Year</td><td class='ar'>" & fv362 & "</td></tr>" &
    "<tr style='background:#1a4a7a;'><td style='padding:8px 10px;'></td><td style='padding-left:10px;font-size:12px;font-weight:700;color:#fff;'>TOTAL CAPITAL</td><td style='text-align:right;font-family:Consolas,monospace;font-size:12px;font-weight:700;color:#fff;'>" & fvTotCap & "</td></tr>" &
    "<tr style='height:6px;'><td colspan='3'></td></tr>" &
    "<tr style='background:#f0a500;'><td style='padding:9px 10px;'></td><td style='padding-left:10px;font-size:13px;font-weight:800;color:#003366;border-top:3px solid #003366;'>TOTAL LIABILITIES &amp; CAPITAL</td><td style='text-align:right;font-family:Consolas,monospace;font-size:13px;font-weight:800;color:#003366;border-top:3px solid #003366;padding:9px 10px;'>" & fvTotAll & "</td></tr>" &
    "</tbody></table>"
VAR FooterHTML =
    "<div style='background:#f8fafc;border-top:1px solid #e2e8f0;padding:7px 15px;display:flex;justify-content:space-between;'>" &
    "<span style='font-family:Segoe UI;font-size:10px;color:#9ca3af;'>All amounts in USD &nbsp;|&nbsp; ( ) denotes negative values</span>" &
    "<span style='font-family:Segoe UI;font-size:10px;color:#9ca3af;'>BNCTL &mdash; Confidential</span>" &
    "</div>"
RETURN
    "<div style='font-family:Segoe UI,Calibri,sans-serif;color:#1e2d40;background:#fff;'>" &
    StyleBlock & ModernHeader &
    "<div style='overflow-x:auto;'>" & TableHTML & "</div>" &
    FooterHTML & "</div>"
