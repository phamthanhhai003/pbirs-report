    "<div style='color:#f0a500;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:3px;'>CONSOLIDATED STATEMENT OF ASSETS AND LIABILITIES (SOC)</div>" &
