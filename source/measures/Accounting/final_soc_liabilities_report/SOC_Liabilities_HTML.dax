VAR Sty =
    "<style>" &
    ".soc{font-family:Segoe UI,Calibri,sans-serif;font-size:10.5px;color:#1e2d40;}" &
    ".soc-t{width:100%;border-collapse:collapse;}" &
    ".soc-t td{padding:3px 7px;border-bottom:1px solid #e8edf3;vertical-align:middle;white-space:nowrap;}" &
    ".soc-t tr:hover td{background:#f5f8ff;}" &
    ".h-row td{background:#003366!important;color:#fff!important;font-weight:700;font-size:11px;text-transform:uppercase;border-bottom:3px solid #f0a500!important;padding:6px 7px!important;}" &
    ".sub1 td{background:#e8f0fb!important;font-weight:700;color:#003366;border-bottom:1px solid #b8cce4!important;}" &
    ".sub2 td{background:#f0f6ff!important;font-weight:600;color:#1a4a7a;}" &
    ".tot td{background:#f0a500!important;font-weight:800;font-size:11px;color:#003366!important;border-top:2px solid #003366!important;}" &
    ".cd{color:#9ca3af;font-size:9px;min-width:80px;}" &
    ".cd-w{color:#f0a500!important;font-size:9px;min-width:80px;}" &
    ".ar{text-align:right!important;font-family:Consolas,monospace;font-size:9.5px;min-width:90px;}" &
    ".ac{text-align:center!important;font-family:Consolas,monospace;font-size:9.5px;min-width:50px;}" &
    ".pct{text-align:center!important;font-size:9.5px;min-width:60px;}" &
    ".bl{border-left:2px solid #dde4ef!important;}" &
