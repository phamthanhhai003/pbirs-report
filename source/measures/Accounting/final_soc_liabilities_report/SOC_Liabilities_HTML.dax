    "<tr><td class='cd'></td><td class='i2'>Total Liabilities &amp; Capital</td>" & "<td class='ac bl'>" & IF(o79_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o79_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o79_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o79_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o79_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o79_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o79_CI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o79_CI>0,"<span style='color:#16a34a'>+" & FORMAT(o79_CI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o79_CI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o79_CP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o79_CP>0,"<span style='color:#16a34a'>+" & FORMAT(o79_CP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o79_CP*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o79_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o79_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o79_YI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o79_YI>0,"<span style='color:#16a34a'>+" & FORMAT(o79_YI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o79_YI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o79_YP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o79_YP>0,"<span style='color:#16a34a'>+" & FORMAT(o79_YP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o79_YP*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
