    "<tr><td class='cd'></td><td class='i2'>Total Capital in CRF</td>" & "<td class='ac bl'>" & IF(o81_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o81_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o81_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o81_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o81_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o81_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o81_CI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o81_CI>0,"<span style='color:#16a34a'>+" & FORMAT(o81_CI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o81_CI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o81_CP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o81_CP>0,"<span style='color:#16a34a'>+" & FORMAT(o81_CP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o81_CP*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o81_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o81_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o81_YI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o81_YI>0,"<span style='color:#16a34a'>+" & FORMAT(o81_YI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o81_YI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o81_YP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o81_YP>0,"<span style='color:#16a34a'>+" & FORMAT(o81_YP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o81_YP*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr><td class='cd'></td><td class='i2'>Diference Assent and Liability</td>" & "<td class='ac bl'>" & IF(o82_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o82_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o82_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o82_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o82_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o82_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o82_CI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o82_CI>0,"<span style='color:#16a34a'>+" & FORMAT(o82_CI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o82_CI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o82_CP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o82_CP>0,"<span style='color:#16a34a'>+" & FORMAT(o82_CP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o82_CP*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o82_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o82_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o82_YI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o82_YI>0,"<span style='color:#16a34a'>+" & FORMAT(o82_YI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o82_YI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o82_YP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o82_YP>0,"<span style='color:#16a34a'>+" & FORMAT(o82_YP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o82_YP*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr class='h-row'><td class='cd-w'>9999</td><td class='i0'>Sistem Internal Error Account</td><td colspan='8'></td></tr>" &
    "<tr class='tot'><td class='cd-w'></td><td class='i0'>TOTAL LIABILITIES &amp; CAPITAL ACCOUNTS</td><td colspan='8'></td></tr>"
VAR Ftr =
    "<div style='background:#f8fafc;border-top:1px solid #e2e8f0;padding:7px 15px;display:flex;justify-content:space-between;'>" &
    "<span style='font-size:10px;color:#9ca3af;'>USD &nbsp;|&nbsp; <span style='color:#16a34a;'>+</span>=increase &nbsp;<span style='color:#dc2626;'>( )</span>=decrease</span>" &
    "<span style='font-size:10px;color:#9ca3af;'>BNCTL &mdash; Confidential</span>" &
    "</div>"
RETURN
    "<div class='soc'>" & Sty & Hdr &
    "<div style='overflow-x:auto;'>" & ColHdr &
    Rows_1 &
    Rows_2 &
    Rows_3 &
    Rows_4 &
    Rows_5 &
    Rows_6 &
    Rows_7 &
    "</tbody></table></div>" &
    Ftr & "</div>"
