    "</tr></thead><tbody>"
VAR Rows_1 =
    "<tr class='sub1'><td class='cd'>2.0</td><td class='i1'>LIABILITIES:</td>" & "<td class='ac bl'>" & IF(o1_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o1_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o1_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o1_CI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o1_CI>0,"<span style='color:#16a34a'>+" & FORMAT(o1_CI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o1_CI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o1_CP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o1_CP>0,"<span style='color:#16a34a'>+" & FORMAT(o1_CP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o1_CP*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o1_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o1_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o1_YI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o1_YI>0,"<span style='color:#16a34a'>+" & FORMAT(o1_YI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o1_YI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o1_YP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o1_YP>0,"<span style='color:#16a34a'>+" & FORMAT(o1_YP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o1_YP*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
    "<tr class='sub1'><td class='cd'>2.04</td><td class='i1'>DEPOSITS</td>" & "<td class='ac bl'>" & IF(o2_CURR_ac=0,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_CURR_ac,"#,##0")) & "</td>" & "<td class='ar'>" & IF(o2_CURR_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_CURR_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o2_PREV_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_PREV_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o2_CI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o2_CI>0,"<span style='color:#16a34a'>+" & FORMAT(o2_CI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o2_CI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o2_CP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o2_CP>0,"<span style='color:#16a34a'>+" & FORMAT(o2_CP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o2_CP*100,"0.00") & "%</span>")) & "</td>" & "<td class='ar bl'>" & IF(o2_YOY_am<0.01,"<span style='color:#d1d5db'>-</span>",FORMAT(o2_YOY_am,"#,##0.00")) & "</td>" & "<td class='ar bl'>" & IF(o2_YI<0.01,"<span style='color:#d1d5db'>-</span>",IF(o2_YI>0,"<span style='color:#16a34a'>+" & FORMAT(o2_YI,"#,##0.00") & "</span>","<span style='color:#dc2626'>(" & FORMAT(o2_YI,"#,##0.00") & ")</span>")) & "</td>" & "<td class='pct'>" & IF(o2_YP<0.0001,"<span style='color:#d1d5db'>-</span>",IF(o2_YP>0,"<span style='color:#16a34a'>+" & FORMAT(o2_YP*100,"0.00") & "%</span>","<span style='color:#dc2626'>" & FORMAT(o2_YP*100,"0.00") & "%</span>")) & "</td>" & "</tr>" &
