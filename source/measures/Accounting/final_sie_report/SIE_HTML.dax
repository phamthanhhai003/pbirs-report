VAR StyleBlock =
    "<style>.sie{font-family:Segoe UI,Calibri,sans-serif;font-size:11px;color:#1e2d40;}" &
    ".sie-t{width:100%;border-collapse:collapse;}" &
    ".sie-t td{padding:3px 12px;border-bottom:1px solid #e8edf3;}" &
    ".sie-t tr:hover td{background:#f5f8ff;}" &
    ".h-row td{background:#003366!important;color:#fff!important;font-weight:700;font-size:12px;text-transform:uppercase;border-bottom:3px solid #f0a500!important;padding:7px 12px!important;}" &
    ".sub1 td{background:#e8f0fb!important;font-weight:700;color:#003366;border-bottom:1px solid #b8cce4!important;}" &
    ".sub2 td{background:#f0f6ff!important;font-weight:600;color:#1a4a7a;}" &
    ".tot td{background:#f0a500!important;font-weight:800;font-size:12px;color:#003366!important;border-top:2px solid #003366!important;}" &
    ".net td{background:#003366!important;font-weight:800;color:#fff!important;border-bottom:3px solid #f0a500!important;}" &
    ".cd{color:#9ca3af;font-size:9px;width:110px;}" &
    ".cd-w{color:#f0a500!important;font-size:9px;width:110px;}" &
    ".ar{text-align:right!important;font-family:Consolas,monospace;font-size:10px;white-space:nowrap;width:130px;}" &
    ".i0{padding-left:10px!important;}" &
    ".i1{padding-left:20px!important;}" &
    ".i2{padding-left:32px!important;}" &
    ".i3{padding-left:44px!important;color:#6b7280;}" &
    ".i4{padding-left:56px!important;color:#9ca3af;}" &
    "</style>"
VAR ModernHeader =
    "<div style='background:#003366;padding:16px 25px 12px;border-bottom:4px solid #f0a500;display:flex;align-items:center;gap:16px;'>" &
    "<img src='https://i.ibb.co/rWhBLgw/image-2026-04-21-094244962.png' style='height:90px;width:auto;flex-shrink:0;' />" &
    "<div>" &
    "<div style='color:#fff;font-family:Segoe UI,sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;'>BANCO NACIONAL DE COMERCIO DE TIMOR LESTE</div>" &
    "<div style='color:#f0a500;font-family:Segoe UI,sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:6px;'>CONSOLIDATED STATEMENT OF INCOME &amp; EXPENSE (SIE)</div>" &
    "<div style='color:#cbd5e1;font-family:Segoe UI,sans-serif;font-size:12px;'>" & PeriodLabel & "</div>" &
    "</div>" &
    "</div>"
VAR TableHTML =
    "<table class='sie-t'><thead><tr style='background:#f8fafc;'><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:110px;'>CODE</td><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;'>DESCRIPTION</td><td style='text-align:right;font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:130px;'>AMOUNT (USD)</td></tr></thead><tbody>" &
    "<tr class='h-row'><td class='cd-w'>4.0</td><td class='i0'>INCOME :</td><td class='ar'></td></tr>" &
    "<tr class='sub1'><td class='cd'>4.01</td><td class='i1'>INTEREST INCOME</td><td class='ar'>" & IF(r7=0,"<span style='color:#d1d5db'>-</span>",IF(r7<0,"<span style='color:#dc2626'>(" & FORMAT(r7,"#,##0.00") & ")</span>",FORMAT(r7,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.1</td><td class='i2'>Interest on Due from Banks</td><td class='ar'>" & IF(r8=0,"<span style='color:#d1d5db'>-</span>",IF(r8<0,"<span style='color:#dc2626'>(" & FORMAT(r8,"#,##0.00") & ")</span>",FORMAT(r8,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.2</td><td class='i2'>Interest on Overnight Placement</td><td class='ar'>" & IF(r9=0,"<span style='color:#d1d5db'>-</span>",IF(r9<0,"<span style='color:#dc2626'>(" & FORMAT(r9,"#,##0.00") & ")</span>",FORMAT(r9,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.3</td><td class='i2'>Interest on Securities</td><td class='ar'>" & IF(r10=0,"<span style='color:#d1d5db'>-</span>",IF(r10<0,"<span style='color:#dc2626'>(" & FORMAT(r10,"#,##0.00") & ")</span>",FORMAT(r10,"#,##0.00"))) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>4.01.4</td><td class='i2'>Interest &amp; Fees on Loans &amp; Discounts</td><td class='ar'>" & IF(r11=0,"<span style='color:#d1d5db'>-</span>",IF(r11<0,"<span style='color:#dc2626'>(" & FORMAT(r11,"#,##0.00") & ")</span>",FORMAT(r11,"#,##0.00"))) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>4.01.4.1</td><td class='i3'>Interest Income on Loans</td><td class='ar'>" & IF(r12=0,"<span style='color:#d1d5db'>-</span>",IF(r12<0,"<span style='color:#dc2626'>(" & FORMAT(r12,"#,##0.00") & ")</span>",FORMAT(r12,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.10</td><td class='i4'>Market Vendor Daily Loans</td><td class='ar'>" & IF(r13=0,"<span style='color:#d1d5db'>-</span>",IF(r13<0,"<span style='color:#dc2626'>(" & FORMAT(r13,"#,##0.00") & ")</span>",FORMAT(r13,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.20</td><td class='i4'>Seasonal Crop Loans</td><td class='ar'>" & IF(r14=0,"<span style='color:#d1d5db'>-</span>",IF(r14<0,"<span style='color:#dc2626'>(" & FORMAT(r14,"#,##0.00") & ")</span>",FORMAT(r14,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.30</td><td class='i4'>Other Business Loan</td><td class='ar'>" & IF(r15=0,"<span style='color:#d1d5db'>-</span>",IF(r15<0,"<span style='color:#dc2626'>(" & FORMAT(r15,"#,##0.00") & ")</span>",FORMAT(r15,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.10</td><td class='i4'>Microfinance Group Loans</td><td class='ar'>" & IF(r16=0,"<span style='color:#d1d5db'>-</span>",IF(r16<0,"<span style='color:#dc2626'>(" & FORMAT(r16,"#,##0.00") & ")</span>",FORMAT(r16,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.20</td><td class='i4'>Payroll Loans</td><td class='ar'>" & IF(r17=0,"<span style='color:#d1d5db'>-</span>",IF(r17<0,"<span style='color:#dc2626'>(" & FORMAT(r17,"#,##0.00") & ")</span>",FORMAT(r17,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.30</td><td class='i4'>Employee and Staff Loans</td><td class='ar'>" & IF(r18=0,"<span style='color:#d1d5db'>-</span>",IF(r18<0,"<span style='color:#dc2626'>(" & FORMAT(r18,"#,##0.00") & ")</span>",FORMAT(r18,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.60</td><td class='i4'>Asuwa&#39;in Loan</td><td class='ar'>" & IF(r19=0,"<span style='color:#d1d5db'>-</span>",IF(r19<0,"<span style='color:#dc2626'>(" & FORMAT(r19,"#,##0.00") & ")</span>",FORMAT(r19,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.70</td><td class='i4'>Bukae Loan</td><td class='ar'>" & IF(r20=0,"<span style='color:#d1d5db'>-</span>",IF(r20<0,"<span style='color:#dc2626'>(" & FORMAT(r20,"#,##0.00") & ")</span>",FORMAT(r20,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.80</td><td class='i4'>Pension Loan</td><td class='ar'>" & IF(r21=0,"<span style='color:#d1d5db'>-</span>",IF(r21<0,"<span style='color:#dc2626'>(" & FORMAT(r21,"#,##0.00") & ")</span>",FORMAT(r21,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.40</td><td class='i4'>Project Loan</td><td class='ar'>" & IF(r22=0,"<span style='color:#d1d5db'>-</span>",IF(r22<0,"<span style='color:#dc2626'>(" & FORMAT(r22,"#,##0.00") & ")</span>",FORMAT(r22,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.50</td><td class='i4'>Investment Loan</td><td class='ar'>" & IF(r23=0,"<span style='color:#d1d5db'>-</span>",IF(r23<0,"<span style='color:#dc2626'>(" & FORMAT(r23,"#,##0.00") & ")</span>",FORMAT(r23,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.85</td><td class='i4'>Transport Loan</td><td class='ar'>" & IF(r24=0,"<span style='color:#d1d5db'>-</span>",IF(r24<0,"<span style='color:#dc2626'>(" & FORMAT(r24,"#,##0.00") & ")</span>",FORMAT(r24,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.90</td><td class='i4'>FIAR Loan</td><td class='ar'>" & IF(r25=0,"<span style='color:#d1d5db'>-</span>",IF(r25<0,"<span style='color:#dc2626'>(" & FORMAT(r25,"#,##0.00") & ")</span>",FORMAT(r25,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.5.10</td><td class='i4'>Agricultor Loan</td><td class='ar'>" & IF(r26=0,"<span style='color:#d1d5db'>-</span>",IF(r26<0,"<span style='color:#dc2626'>(" & FORMAT(r26,"#,##0.00") & ")</span>",FORMAT(r26,"#,##0.00"))) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.5.11</td><td class='i4'>RBL Loan Origination</td><td class='ar'>" & IF(r27=0,"<span style='color:#d1d5db'>-</span>",IF(r27<0,"<span style='color:#dc2626'>(" & FORMAT(r27,"#,##0.00") & ")</span>",FORMAT(r27,"#,##0.00"))) & "</td></tr>" &
    "<tr class='h-row'><td class='cd-w'>4.01.4.2</td><td class='i0'>Loan Fees</td><td class='ar'></td></tr>" &
