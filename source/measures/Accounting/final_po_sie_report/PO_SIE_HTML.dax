    "<tr class='h-row'><td class='cd-w'>5.0</td><td>E X P E N S E</td><td class='ar'></td></tr>" &
    "<tr class='sub1'><td class='cd'>5.01</td><td class='i1'>INTEREST EXPENSE</td><td class='ar'>" & IF(r64=0,z,FORMAT(r64,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.01.2</td><td class='i2'>Interest by Individual Deposits</td><td class='ar'>" & IF(r65=0,z,FORMAT(r65,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.01.2.1</td><td class='i3'>Saving Deposits</td><td class='ar'>" & IF(r66=0,z,FORMAT(r66,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.01.2.2</td><td class='i3'>Time Deposits</td><td class='ar'>" & IF(r67=0,z,FORMAT(r67,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.01.2.2</td><td class='i3'>Demand Deposits</td><td class='ar'>" & IF(r68=0,z,FORMAT(r68,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.01.3</td><td class='i2'>Interest on Legal Entities Deposits</td><td class='ar'>" & IF(r69=0,z,FORMAT(r69,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.01.3.1</td><td class='i3'>Saving Deposits (Legal)</td><td class='ar'>" & IF(r70=0,z,FORMAT(r70,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.01.5</td><td class='i2'>Interest Expense on Other Borrowing</td><td class='ar'>" & IF(r71=0,z,FORMAT(r71,f)) & "</td></tr>" &
    "<tr class='sub1'><td class='cd'>5.02</td><td class='i1'>NON INTEREST EXPENSE</td><td class='ar'>" & IF(r72=0,z,FORMAT(r72,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.02.3</td><td class='i2'>Foreign Exchanges Losses</td><td class='ar'>" & IF(r73=0,z,FORMAT(r73,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.02.4</td><td class='i2'>Commission Expense &amp; Transaction Fees</td><td class='ar'>" & IF(r74=0,z,FORMAT(r74,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.02.5</td><td class='i2'>Other Non Interest Expense (License Fee)</td><td class='ar'>" & IF(r75=0,z,FORMAT(r75,f)) & "</td></tr>" &
    "<tr class='sub1'><td class='cd'>5.03</td><td class='i1'>OPERATING EXPENSE</td><td class='ar'>" & IF(r76=0,z,FORMAT(r76,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.1</td><td class='i2'>Salaries and Employee Benefits</td><td class='ar'>" & IF(r77=0,z,FORMAT(r77,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.1</td><td class='i3'>Remunerations of Board of Director</td><td class='ar'>" & IF(r78=0,z,FORMAT(r78,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.2</td><td class='i3'>Directors Fees and Honoraria</td><td class='ar'>" & IF(r79=0,z,FORMAT(r79,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.1</td><td class='i3'>Salaries and Wages</td><td class='ar'>" & IF(r80=0,z,FORMAT(r80,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.3</td><td class='i3'>Fringe Benefits - Employee</td><td class='ar'>" & IF(r81=0,z,FORMAT(r81,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.5</td><td class='i3'>Contribution to Retirement Fund</td><td class='ar'>" & IF(r82=0,z,FORMAT(r82,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.6</td><td class='i3'>Annual Leave</td><td class='ar'>" & IF(r83=0,z,FORMAT(r83,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.1.7</td><td class='i3'>Payment for Overtime</td><td class='ar'>" & IF(r84=0,z,FORMAT(r84,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.2</td><td class='i2'>Administrative Expenses</td><td class='ar'>" & IF(r85=0,z,FORMAT(r85,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.10</td><td class='i3'>Information Tech./Automation</td><td class='ar'>" & IF(r87=0,z,FORMAT(r87,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.15</td><td class='i3'>Communication Expense</td><td class='ar'>" & IF(r88=0,z,FORMAT(r88,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.20</td><td class='i3'>Power, Light and Water</td><td class='ar'>" & IF(r89=0,z,FORMAT(r89,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.25</td><td class='i3'>Fuel and Lubricants</td><td class='ar'>" & IF(r90=0,z,FORMAT(r90,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.30</td><td class='i3'>Traveling Expenses</td><td class='ar'>" & IF(r91=0,z,FORMAT(r91,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.35</td><td class='i3'>Stationery and Office Supplies</td><td class='ar'>" & IF(r92=0,z,FORMAT(r92,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.40</td><td class='i3'>Representation and Entertainment</td><td class='ar'>" & IF(r93=0,z,FORMAT(r93,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.2.4.1.45</td><td class='i3'>Repairs and Maintenance</td><td class='ar'>" & IF(r94=0,z,FORMAT(r94,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.3</td><td class='i2'>Advertising and Public Relation</td><td class='ar'>" & IF(r95=0,z,FORMAT(r95,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.4</td><td class='i2'>Audit, Legal &amp; Professional Fees</td><td class='ar'>" & IF(r96=0,z,FORMAT(r96,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.5</td><td class='i2'>Rents Paid</td><td class='ar'>" & IF(r97=0,z,FORMAT(r97,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.5.1</td><td class='i3'>Rent Paid</td><td class='ar'>" & IF(r98=0,z,FORMAT(r98,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.5.1</td><td class='i3'>Car Rents</td><td class='ar'>" & IF(r99=0,z,FORMAT(r99,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.6</td><td class='i2'>Expense on Premises and Fixed Assets</td><td class='ar'>" & IF(r100=0,z,FORMAT(r100,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.6.1</td><td class='i3'>Insurance</td><td class='ar'>" & IF(r101=0,z,FORMAT(r101,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.6.3</td><td class='i3'>Building Maintenance</td><td class='ar'>" & IF(r102=0,z,FORMAT(r102,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.7</td><td class='i2'>Depreciation and Amortization</td><td class='ar'>" & IF(r103=0,z,FORMAT(r103,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.3</td><td class='i3'>Depr. Machinery &amp; Equipment</td><td class='ar'>" & IF(r104=0,z,FORMAT(r104,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.4</td><td class='i3'>Depr. Furniture &amp; Fixture</td><td class='ar'>" & IF(r105=0,z,FORMAT(r105,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.5</td><td class='i3'>Depr. Vehicles</td><td class='ar'>" & IF(r106=0,z,FORMAT(r106,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.6</td><td class='i3'>Depr. Non Physical Assets</td><td class='ar'>" & IF(r107=0,z,FORMAT(r107,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.7</td><td class='i3'>Amort. Leasehold Right &amp; Improvement</td><td class='ar'>" & IF(r108=0,z,FORMAT(r108,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.7.8</td><td class='i3'>Amort. Building</td><td class='ar'>" & IF(r109=0,z,FORMAT(r109,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.8</td><td class='i2'>Provision</td><td class='ar'>" & IF(r111=0,z,FORMAT(r111,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.8.1</td><td class='i3'>Provision for Loans Losses</td><td class='ar'>" & IF(r112=0,z,FORMAT(r112,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>5.03.9</td><td class='i2'>Other Operating Expense</td><td class='ar'>" & IF(r113=0,z,FORMAT(r113,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.9.1.1.05</td><td class='i3'>Security, Janitorial &amp; Messengerial</td><td class='ar'>" & IF(r114=0,z,FORMAT(r114,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.9.1.1.66</td><td class='i3'>Health Expenses</td><td class='ar'>" & IF(r118=0,z,FORMAT(r118,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.9.1.1.75</td><td class='i3'>Training Expenses</td><td class='ar'>" & IF(r125=0,z,FORMAT(r125,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.9.1.1.82</td><td class='i3'>Miscellaneous - Contingency</td><td class='ar'>" & IF(r130=0,z,FORMAT(r130,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.03.9.1.1.78</td><td class='i3'>Miscellaneous - Others</td><td class='ar'>" & IF(r133=0,z,FORMAT(r133,f)) & "</td></tr>" &
    "<tr class='sub1'><td class='cd'>5.04</td><td class='i1'>EXTRAORDINARY EXPENSE</td><td class='ar'>" & IF(r135=0,z,FORMAT(r135,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.04.1</td><td class='i2'>Losses with disposal of Fixed Assets</td><td class='ar'>" & IF(r136=0,z,FORMAT(r136,f)) & "</td></tr>" &
    "<tr><td class='cd'>5.04.3</td><td class='i2'>Other Extraordinary Expenses</td><td class='ar'>" & IF(r138=0,z,FORMAT(r138,f)) & "</td></tr>" &
    "<tr class='tot'><td class='cd-w'></td><td>TOTAL OPERATING EXPENSES</td><td class='ar'>" & IF(r139=0,z,FORMAT(r139,f)) & "</td></tr>" &
    "<tr style='height:8px;background:#f1f5f9;'><td colspan='3'></td></tr>" &
    "<tr class='net'><td class='cd-w'></td><td>NET INCOME (LOSS) BEFORE TAX</td><td class='ar' style='color:" & IF(r140>=0,"#f0a500","#ff6b6b") & "!important;'>" & IF(r140=0,z,FORMAT(r140,f)) & "</td></tr>" &
    "<tr class='tax'><td class='cd-w'>5.09</td><td class='i1'>PROVISION FOR INCOME TAX</td><td class='ar'>" & IF(r141=0,z,FORMAT(r141,f)) & "</td></tr>" &
    "<tr class='net'><td class='cd-w'></td><td>NET INCOME (LOSS) AFTER TAX</td><td class='ar' style='color:" & IF(r142>=0,"#f0a500","#ff6b6b") & "!important;'>" & IF(r142=0,z,FORMAT(r142,f)) & "</td></tr>" &
    "</tbody></table>"
VAR FooterHTML =
    "<div style='background:#f8fafc;border-top:1px solid #e2e8f0;padding:7px 15px;display:flex;justify-content:space-between;'>" &
    "<span style='font-family:Segoe UI;font-size:10px;color:#9ca3af;'>All amounts in USD</span>" &
    "<span style='font-family:Segoe UI;font-size:10px;color:#9ca3af;'>BNCTL &mdash; Confidential</span>" &
    "</div>"
RETURN
    "<div class='sie'>" & StyleBlock & ModernHeader &
    "<div style='overflow-x:auto;'>" & TableHTML & "</div>" &
    FooterHTML & "</div>"
