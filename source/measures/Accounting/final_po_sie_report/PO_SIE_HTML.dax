VAR f = "#,##0.00"
VAR z = "<span style='color:#d1d5db'>-</span>"
VAR StyleBlock =
    "<style>" &
    ".sie{font-family:Segoe UI,Calibri,sans-serif;font-size:11px;color:#1e2d40;}" &
    ".sie-t{width:100%;border-collapse:collapse;}" &
    ".sie-t td{padding:3px 12px;border-bottom:1px solid #e8edf3;vertical-align:middle;}" &
    ".sie-t tr:hover td{background:#f5f8ff;}" &
    ".h-row td{background:#003366!important;color:#fff!important;font-weight:700;font-size:12px;text-transform:uppercase;border-bottom:3px solid #f0a500!important;padding:7px 12px!important;}" &
    ".sub1 td{background:#e8f0fb!important;font-weight:700;color:#003366;border-bottom:1px solid #b8cce4!important;}" &
    ".sub2 td{background:#f0f6ff!important;font-weight:600;color:#1a4a7a;}" &
    ".tot td{background:#f0a500!important;font-weight:800;font-size:12px;color:#003366!important;border-top:2px solid #003366!important;}" &
    ".net td{background:#003366!important;font-weight:800;font-size:13px;color:#fff!important;border-bottom:3px solid #f0a500!important;}" &
    ".tax td{background:#1a4a7a!important;font-weight:700;color:#fff!important;}" &
    ".cd{color:#9ca3af;font-size:9px;width:110px;}" &
    ".cd-w{color:#f0a500!important;font-size:9px;width:110px;}" &
    ".ar{text-align:right!important;font-family:Consolas,monospace;font-size:10px;white-space:nowrap;width:130px;}" &
    ".i1{padding-left:20px!important;}" &
    ".i2{padding-left:32px!important;}" &
    ".i3{padding-left:44px!important;color:#6b7280;}" &
    ".i4{padding-left:56px!important;color:#9ca3af;}" &
    "</style>"
VAR ModernHeader =
    "<div style='background:#003366;padding:16px 25px 12px;border-bottom:4px solid #f0a500;display:flex;align-items:center;gap:16px;'>" &
    "<img src='https://i.ibb.co/rWhBLgw/image-2026-04-21-094244962.png' style='height:90px;width:auto;flex-shrink:0;' />" &
    "<div>" &
    "<div style='color:#fff;font-family:Segoe UI,sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;'>BANCO NACIONAL DE COMERCIO DE TIMOR LESTE</div>" &
    "<div style='color:#f0a500;font-family:Segoe UI,sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:6px;'>CONSOLIDATED STATEMENT OF INCOME &amp; EXPENSE (PO SIE)</div>" &
    "<div style='color:#cbd5e1;font-family:Segoe UI,sans-serif;font-size:12px;'>" & PeriodLabel & "</div>" &
    "</div>" &
    "</div>"
VAR TableHTML =
    "<table class='sie-t'><thead><tr style='background:#f8fafc;'><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:110px;'>CODE</td><td style='font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;'>DESCRIPTION</td><td style='text-align:right;font-size:10px;font-weight:700;color:#003366;padding:6px 12px;border-bottom:2px solid #003366;width:130px;'>AMOUNT (USD)</td></tr></thead><tbody>" &
    "<tr class='h-row'><td class='cd-w'>4.0</td><td>I N C O M E</td><td class='ar'></td></tr>" &
    "<tr class='sub1'><td class='cd'>4.01</td><td class='i1'>INTEREST INCOME</td><td class='ar'>" & IF(r8=0,z,FORMAT(r8,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.1</td><td class='i2'>Interest on Due from Banks</td><td class='ar'>" & IF(r9=0,z,FORMAT(r9,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.2</td><td class='i2'>Interest on Overnight Placement</td><td class='ar'>" & IF(r10=0,z,FORMAT(r10,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.3</td><td class='i2'>Interest on Securities</td><td class='ar'>" & IF(r11=0,z,FORMAT(r11,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>4.01.4</td><td class='i2'>Interest &amp; Fees on Loans &amp; Discounts</td><td class='ar'>" & IF(r12=0,z,FORMAT(r12,f)) & "</td></tr>" &
    "<tr class='sub2'><td class='cd'>4.01.4.1</td><td class='i3'>Interest Income on Loans</td><td class='ar'>" & IF(r13=0,z,FORMAT(r13,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.10</td><td class='i4'>Market Vendor Daily Loans</td><td class='ar'>" & IF(r14=0,z,FORMAT(r14,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.20</td><td class='i4'>Seasonal Crop Loans</td><td class='ar'>" & IF(r15=0,z,FORMAT(r15,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.3.30</td><td class='i4'>Other Business Loan</td><td class='ar'>" & IF(r16=0,z,FORMAT(r16,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.10</td><td class='i4'>Microfinance Group Loans</td><td class='ar'>" & IF(r17=0,z,FORMAT(r17,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.20</td><td class='i4'>Payroll Loans</td><td class='ar'>" & IF(r18=0,z,FORMAT(r18,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.30</td><td class='i4'>Employee and Staff Loans</td><td class='ar'>" & IF(r19=0,z,FORMAT(r19,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.60</td><td class='i4'>Asuwa'in Loan</td><td class='ar'>" & IF(r20=0,z,FORMAT(r20,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.70</td><td class='i4'>Bukae Loan</td><td class='ar'>" & IF(r21=0,z,FORMAT(r21,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.80</td><td class='i4'>Pension Loan</td><td class='ar'>" & IF(r22=0,z,FORMAT(r22,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.1.4.40</td><td class='i4'>Project Loan</td><td class='ar'>" & IF(r23=0,z,FORMAT(r23,f)) & "</td></tr>" &
