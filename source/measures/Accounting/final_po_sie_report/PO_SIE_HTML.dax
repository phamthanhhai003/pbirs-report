    "<tr><td class='cd'>4.02.0</td><td class='i3'>ATM Fee</td><td class='ar'>" & IF(r49=0,z,FORMAT(r49,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.02.2</td><td class='i3'>MoneyGram Fees</td><td class='ar'>" & IF(r50=0,z,FORMAT(r50,f)) & "</td></tr>" &
