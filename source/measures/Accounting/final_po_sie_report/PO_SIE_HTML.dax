    "<tr><td class='cd'>4.01.4.3.4</td><td class='i4'>Loan Fee - Seasonal Crop</td><td class='ar'>" & IF(r32=0,z,FORMAT(r32,f)) & "</td></tr>" &
    "<tr><td class='cd'>4.01.4.3.5</td><td class='i4'>Loan Fee - Business Loan</td><td class='ar'>" & IF(r33=0,z,FORMAT(r33,f)) & "</td></tr>" &
