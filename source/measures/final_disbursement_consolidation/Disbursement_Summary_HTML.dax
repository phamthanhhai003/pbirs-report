VAR Ftr = "<div style='background:#f8fafc;border-top:1px solid #e2e8f0;padding:6px 14px;font-size:10px;color:#9ca3af;'>Amt=Amount(USD) | Acct=Number of Accounts &mdash; BNCTL Confidential</div>"
VAR Sty = "<style>.ds{font-family:Segoe UI,Calibri,sans-serif;font-size:9.5px;color:#1e2d40;}.ds-t{width:100%;border-collapse:collapse;}.ds-t td{padding:3px 5px;border-bottom:1px solid #e8edf3;vertical-align:middle;white-space:nowrap;}.ds-t tr:hover td{background:#f5f8ff;}.th{background:#003366!important;color:#fff!important;font-weight:700;font-size:9px;text-transform:uppercase;border-bottom:3px solid #f0a500!important;padding:5px 5px!important;text-align:center;}.thl{text-align:left!important;}.mh{background:#1a4a7a!important;color:#fff!important;font-weight:700;font-size:8.5px;text-align:center;border-bottom:1px solid #f0a500!important;padding:3px 5px!important;}.bh td{background:#1a4a7a!important;color:#fff!important;font-weight:700;font-size:11px;border-bottom:2px solid #f0a500!important;padding:5px 10px!important;}.pr td{background:#f8fafc;}.st td{background:#e8f0fb!important;font-weight:700;color:#003366;border-top:1px solid #b8cce4!important;}.gt td{background:#003366!important;color:#fff!important;font-weight:800;font-size:10px;border-top:3px solid #f0a500!important;}.gt td.ar{font-family:Consolas,monospace;text-align:right;color:#f0a500!important;}.ar{text-align:right!important;font-family:Consolas,monospace;font-size:9px;min-width:65px;}.ac{text-align:center!important;font-size:9px;color:#6b7280;min-width:28px;}.bl{border-left:2px solid #dde4ef!important;}.fw{font-weight:700;}.no{font-size:9px;color:#9ca3af;text-align:center;width:22px;}.br{width:14px;}.pn{width:25px;text-align:center;font-size:9px;color:#9ca3af;}.nm{min-width:120px;}.zero{color:#d1d5db;}</style>"
VAR Hdr = "<div style='background:#003366;padding:14px 18px;border-bottom:4px solid #f0a500;display:flex;align-items:center;'><img src='https://i.ibb.co/rWhBLgw/image-2026-04-21-094244962.png' style='height:90px;object-fit:contain;flex-shrink:0;margin-right:20px;' /><div><div style='color:#fff;font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;'>BANCO NACIONAL DE COMERCIO DE TIMOR LESTE</div><div style='color:#f0a500;font-size:11px;font-weight:600;text-transform:uppercase;margin-bottom:3px;'>REKAPITULASAUN DESEMBOLSU PRODUTU KREDITU HUSI SUCURSAL HOTU</div><div style='color:#cbd5e1;font-size:11px;'>" & ActiveYear & "</div></div></div>"
VAR TH = "<table class='ds-t'><thead><tr><td class='th thl' rowspan='2'>Nu.</td><td class='th thl' rowspan='2'>Sukursal</td><td class='th' rowspan='2'>Nu.<br>Prod.</td><td class='th thl' rowspan='2'>Produtu Kreditu</td><td class='th' colspan='2'>JANEIRU</td><td class='th' colspan='2'>FEVEREIRU</td><td class='th' colspan='2'>MARSU</td><td class='th' colspan='2'>ABRIL</td><td class='th' colspan='2'>MAIU</td><td class='th' colspan='2'>JUNU</td><td class='th' colspan='2'>JULLU</td><td class='th' colspan='2'>AGOSTU</td><td class='th' colspan='2'>SETEMBRU</td><td class='th' colspan='2'>OUTUBRU</td><td class='th' colspan='2'>NOVEMBRU</td><td class='th' colspan='2'>DEZEMBRU</td><td class='th' colspan='2' style='background:#f0a500!important;color:#003366!important;'>AKUMULASAUN</td></tr><tr><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td><td class='mh bl'>Amt</td><td class='mh'>Acct</td></tr></thead><tbody>"

RETURN
    "<div class='ds'>" & Sty & Hdr & "<div style='overflow-x:auto;'>" & TH &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "DILI", BH1 & PR1 & ST1, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "GLENO", BH2 & PR2 & ST2, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "MALIANA", BH3 & PR3 & ST3, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "AILEU", BH4 & PR4 & ST4, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "OECUSSE", BH5 & PR5 & ST5, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "BAUCAU", BH6 & PR6 & ST6, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "SAME", BH7 & PR7 & ST7, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "AINARO", BH8 & PR8 & ST8, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "SUAI", BH9 & PR9 & ST9, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "VIQUEQUE", BH10 & PR10 & ST10, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "LOSPALOS", BH11 & PR11 & ST11, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "LIQUICA", BH12 & PR12 & ST12, "") &
    IF(ISBLANK(SelectedBranch) || SelectedBranch = "MANATUTO", BH13 & PR13 & ST13, "") &
    IF(ISBLANK(SelectedBranch), GT, "") &
    "</tbody></table></div>" & Ftr & "</div></div>"

