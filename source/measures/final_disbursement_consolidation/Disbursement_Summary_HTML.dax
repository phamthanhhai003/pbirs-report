MEASURE 'final_disbursement_consolidation'[Disbursement_Summary_HTML] =

VAR SelectedYear   = SELECTEDVALUE( 'Calendar_Disbursement'[Year] )
VAR SelectedBranch = SELECTEDVALUE( final_disbursement_consolidation[Branch] )
VAR MaxYear      = MAXX( FILTER(final_disbursement_consolidation,[amount_total]>0), FORMAT([report_year],"0") )
VAR ActiveYear   = IF( ISBLANK(SelectedYear), MaxYear, SelectedYear )
VAR AYN          = VALUE( ActiveYear )
VAR tbl = FILTER( final_disbursement_consolidation, [report_year]=AYN && [Credit_Product]<>"TOTAL" && NOT ISBLANK([Branch]) )
VAR ttl = FILTER( final_disbursement_consolidation, [report_year]=AYN && [Credit_Product]="TOTAL" )

VAR s1_jana = SUMX(FILTER(ttl,[Branch]="DILI"),[amount_jan])
